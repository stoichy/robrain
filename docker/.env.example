# docker/.env.example
# Copy to docker/.env and fill in values

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings (choose one) ────────────────────────────────────
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-...
# EMBEDDING_PROVIDER=cohere
# COHERE_API_KEY=...

# ── Optional ──────────────────────────────────────────────────
POSTGRES_USER=robrain
POSTGRES_PASSWORD=robrain
POSTGRES_DB=robrain
POSTGRES_PORT=5432
PERCEPTION_PORT=3001

# Shared secret between Sensing MCP and Perception API
# Set to any random string, or leave blank for local dev
PERCEPTION_API_KEY=

# Anthropic model for extraction (Haiku is cheapest)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
