{
  "name": "robrain",
  "version": "0.1.0",
  "description": "Institutional memory for AI coding agents — capture decisions, rejected alternatives, and rationale across sessions",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "build":     "pnpm -r build",
    "dev":       "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "typescript":  "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
