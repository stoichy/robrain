# RoBrain — repo-root environment (single file for Docker + robrain install)
#
# Copy to `.env` at this repo root (same folder as package.json):
#   cp .env.example .env
#
# Or just run `pnpm docker:up` — scripts/prepare-env.mjs will create .env from
# this file if missing AND auto-fill any empty PERCEPTION_API_KEY / POSTGRES_PASSWORD
# with random 32-byte hex values, then rewrite DATABASE_URL to match.
#
# Used by:
#   - `pnpm docker:up` — passes this file to Docker Compose (--env-file .env)
#   - `robrain install --self-hosted --repo-root "$(pwd)"` — loads these vars so you
#     are not prompted again for keys already defined here
#
# Keep EMBEDDING_PROVIDER and the matching embedding API key identical for Perception
# (Docker) and Sensing MCP (written by install) — different providers break vector search.

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings (choose one provider and its key) ──────────────
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-...
# EMBEDDING_PROVIDER=cohere
# COHERE_API_KEY=...

# ── Postgres + Perception (docker-compose) ────────────────────
POSTGRES_USER=robrain
# REQUIRED — leave blank and `pnpm docker:up` will fill in a random 32-byte hex value.
# To set manually:  openssl rand -hex 32
POSTGRES_PASSWORD=
POSTGRES_DB=robrain
POSTGRES_PORT=5432
PERCEPTION_PORT=3001

# Bind hosts for Docker port mappings. Default 127.0.0.1 keeps the stack
# unreachable from the LAN. Set to 0.0.0.0 only if you intentionally want
# remote access AND have set strong PERCEPTION_API_KEY + POSTGRES_PASSWORD.
# POSTGRES_BIND_HOST=127.0.0.1
# PERCEPTION_BIND_HOST=127.0.0.1

# Used by `robrain synth` (Synthesis batch job) to reach the same Postgres Perception uses.
# Host-side connection string — Docker-compose builds its own URL internally for the container.
# `pnpm docker:up` rewrites this to match POSTGRES_PASSWORD when both are auto-generated.
DATABASE_URL=postgres://robrain:CHANGE_ME@localhost:5432/robrain

# Shared secret between Sensing MCP and Perception API.
# REQUIRED in OSS mode unless ALLOW_UNAUTHENTICATED=true (NOT recommended).
# Leave blank and `pnpm docker:up` will fill in a random 32-byte hex value.
# To set manually:  openssl rand -hex 32
PERCEPTION_API_KEY=

# Anthropic model for extraction (Haiku is cheapest)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Set to true to stop calling the embeddings API from Sensing (no topic-shift signal; avoids RPM hits)
# SENSING_TOPIC_SHIFT_DISABLE_EMBEDDING=true

# DANGER — opt out of Perception API auth. Anyone who can reach the port can
# read/write your decision corpus. Only flip this if you know what you are doing.
# ALLOW_UNAUTHENTICATED=true
